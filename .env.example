# ===== SUPABASE =====
# Pegue em: https://app.supabase.com -> seu projeto -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
# Chave service_role (NUNCA exponha no client; só usada em rotas server / admin)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ===== SITE =====
NEXT_PUBLIC_SITE_URL=https://jvwebstudio.com.br
NEXT_PUBLIC_WHATSAPP=5500000000000   # DDI+DDD+numero, ex: 5547999999999

# ===== INSTAGRAM (opcional — ativa o feed real quando você gerar o token) =====
# Instagram Basic Display API: https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
